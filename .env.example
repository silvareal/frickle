# Copy to .env and adjust as needed. Secrets via env only — never commit real ones.
DATABASE_URL=postgresql://demo:demo@postgres:5432/anomaly
AHNLICH_HOST=ahnlich
AHNLICH_PORT=1369
# Text embedder: "ahnlich_ai" (offload to the ahnlich-ai proxy) or
# "sentence_transformers" (run all-MiniLM-L6-v2 in-process).
EMBEDDER=ahnlich_ai
AHNLICH_AI_HOST=ahnlich-ai
AHNLICH_AI_PORT=1370
ARTIFACT_DIR=/artifacts
STORE_NAME=transactions
KNN_K=5
CORS_ORIGINS=http://localhost:5173
VITE_API_BASE=http://localhost:8000
